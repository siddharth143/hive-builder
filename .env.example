# Copy to .env for local runs. Never commit .env or real values.
# Rotate any credentials that were ever committed or shared.

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_LABELS=Education,AI Product Management
DATE_WINDOW_DAYS=7
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
SUMMARISATION_PERSONA=a product manager interested in AI and continuous learning
FILTER_KEYWORDS=unsubscribe,% off,sale,deal,enroll now,cohort starts
MAX_EMAILS_PER_LABEL=50

# Dropbox — obtain a long-lived access token from the Dropbox App Console
# (Settings → OAuth 2 → Generated access token), or use the OAuth flow.
#
# DROPBOX_FOLDER_PATH is the destination inside your Dropbox.
# For an App Folder app:  /Daily Briefs
# For Full Dropbox access: /Obsidian/Daily Notes  (point to your vault folder)
#
# Obsidian tip: set DROPBOX_FOLDER_PATH to the folder inside your Dropbox-synced
# Obsidian vault so the brief appears automatically on each device.
DROPBOX_ACCESS_TOKEN=
DROPBOX_FOLDER_PATH=/Project-Hive/Daily Briefs

# Optional: set to 1 for verbose stderr logs (also supported as a GitHub Actions secret).
# DEBUG=1
